{
  "name": "dynamic-notch",
  "version": "1.0.0",
  "description": "Dynamic Island-style notch overlay for Windows",
  "main": "main.js",
  "scripts": {
    "start": "set ELECTRON_RUN_AS_NODE=&& electron .",
    "kill": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/kill-instances.ps1",
    "fresh": "npm run kill && npm start",
    "build": "electron-builder"
  },
  "dependencies": {
    "@distube/ytdl-core": "^4.16.12",
    "@tabler/icons": "^3.40.0",
    "lottie-web": "^5.13.0",
    "node-fetch": "^2.7.0",
    "node-ical": "^0.26.1",
    "systeminformation": "^5.31.3",
    "weather-js": "^2.0.0",
    "ws": "^8.21.0",
    "yahoo-finance2": "^3.15.3"
  },
  "devDependencies": {
    "electron": "^34.5.8"
  },
  "build": {
    "appId": "com.dynamicnotch.app",
    "productName": "Dynamic Notch",
    "win": {
      "target": "nsis"
    }
  }
}
